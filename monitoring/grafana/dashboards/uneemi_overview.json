{
  "uid": "uneemi-overview",
  "title": "Uneemi MLOps - обзор",
  "tags": ["uneemi", "mlops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Латентность /predict p50/p95/p99 (технический SLI)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(uneemi_predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(uneemi_predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum(rate(uneemi_predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RPS по статусам (технический SLI)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(uneemi_requests_total{endpoint=\"predict\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Доля ошибок (технический SLI)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.005 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(uneemi_requests_total{status=~\"5..|4xx\"}[5m])) / clamp_min(sum(rate(uneemi_requests_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Запросов в обработке",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [{ "refId": "A", "expr": "uneemi_in_flight_requests" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Production-версия модели (model SLI)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "refId": "A", "expr": "uneemi_model_version" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Срывы guardrails (откаты)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "uneemi_guardrail_breaches_total" }]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Доля дрифта признаков (model SLI)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "uneemi_drift_share" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Live ROC-AUC на свежей разметке (model SLI)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0.5, "max": 1.0 },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "uneemi_live_auc", "legendFormat": "live AUC" }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Флаг дрифта набора",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "нет" }, "1": { "text": "ДРИФТ" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "uneemi_dataset_drift" }]
    }
  ]
}
