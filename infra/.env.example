# ============================================================================
# Uneemi MLOps - единый файл конфигурации (12-factor).
# Скопировать в infra/.env и при необходимости поправить. infra/.env в .gitignore.
# ВНИМАНИЕ: значения ниже - дефолты для локальной разработки. Для прода/облака
# перегенерировать секреты (FERNET_KEY, пароли) и не коммитить.
#
# Host-порты выбраны в обход занятых на dev-машине 6379 и 8000.
# Внутри docker-сети сервисы обращаются друг к другу по DNS-именам
# (postgres, redis, minio, mlflow, pushgateway, prometheus), НЕ через localhost.
# ============================================================================

# --- Postgres (общий backend для Airflow и MLflow, разные БД) ---------------
POSTGRES_USER=uneemi
POSTGRES_PASSWORD=uneemi_dev_pass
POSTGRES_DB=airflow
MLFLOW_DB_NAME=mlflow
POSTGRES_HOST_PORT=15432

# --- Redis (online-store Feast) ---------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=16379

# --- MinIO (S3-совместимое хранилище: артефакты MLflow + offline-паркеты) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MLFLOW_BUCKET=mlflow-artifacts
FEAST_BUCKET=feast-offline

# --- AWS/S3 совместимость для boto3 (MLflow, Feast указывают на MinIO) -------
# Ключи совпадают с MinIO root (для прода - отдельный сервисный аккаунт).
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_dev
AWS_DEFAULT_REGION=us-east-1
# Принудительно path-style и эндпоинт MinIO - иначе boto3 ломается о virtual-host.
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_ADDRESSING_STYLE=path

# --- MLflow (Tracking + Model Registry) -------------------------------------
# Пин 2.22.1: в MLflow 3.x удалены стадии Production/Archived, а они нужны по ТЗ.
MLFLOW_HOST_PORT=5500
MLFLOW_TRACKING_URI=http://mlflow:5000
MODEL_NAME=uneemi_match
MODEL_ALIAS=champion

# --- Airflow (LocalExecutor) ------------------------------------------------
# uid 50000 - дефолт официального образа; на Windows-bind важно зафиксировать.
AIRFLOW_UID=50000
AIRFLOW_WWW_USER=admin
AIRFLOW_WWW_PASSWORD=admin
AIRFLOW_WEB_HOST_PORT=18080
AIRFLOW__CORE__FERNET_KEY=9d1DDQh5J7QrxmbBES-9Dz7cm-maqedQN39aiAzit8g=
AIRFLOW__WEBSERVER__SECRET_KEY=d2b67ee450f94be74a21b8d0953c2a7b
# Низкий параллелизм - бережём память на dev-машине с ~11 контейнерами.
AIRFLOW__CORE__PARALLELISM=4
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=4
FEAST_REPO_PATH=/opt/airflow/feature_repo

# --- Serving (FastAPI) ------------------------------------------------------
SERVING_HOST_PORT=18000
# Период опроса MLflow Registry на смену Production-версии (горячая подмена).
POLL_INTERVAL_SEC=15
# Guardrails: при превышении - откат на последнюю Archived-версию.
GUARDRAIL_P99_MS=500
GUARDRAIL_ERROR_RATE=0.005
# Окно скользящей статистики latency/ошибок (число последних запросов).
GUARDRAIL_WINDOW=200

# --- Prometheus / Pushgateway / Grafana -------------------------------------
PROMETHEUS_HOST_PORT=19090
PUSHGATEWAY_HOST=pushgateway
PUSHGATEWAY_PORT=9091
PUSHGATEWAY_HOST_PORT=19091
GRAFANA_HOST_PORT=13000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# --- ML-пороги (гейты пайплайнов) -------------------------------------------
# Гейт качества обучения: минимальный holdout ROC-AUC для промоута.
AUC_THRESHOLD=0.70
# Гейт дрифта мониторинга: доля задрейфивших колонок, выше которой - триггер CT.
DRIFT_THRESHOLD=0.5
# SLO live-качества: ниже этого AUC на свежей разметке - триггер переобучения.
LIVE_AUC_SLO=0.65

# --- Генератор синтетических данных (честный процесс, помечен как демо) ------
# Профилей в банке, пар на обучение, зерно ГПСЧ.
N_PROFILES=600
N_PAIRS=8000
DATA_SEED=42
# Коэффициенты P(match)=sigmoid(a*cos(boardA,boardB) + b*quizSim + N(0,sigma)).
SYNTH_A=6.0
SYNTH_B=2.0
SYNTH_SIGMA=0.8
# Размер банка демо-изображений и число картинок на доску профиля.
DEMO_IMAGES_PER_CLUSTER=18
BOARD_IMAGES_PER_PROFILE=12
