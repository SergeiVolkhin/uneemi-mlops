# Образ MLflow-сервера (C6/C7). Тонкий: официальный образ не несёт psycopg2/boto3
# и curl, поэтому собираем сами - так надёжнее backend Postgres + артефакты MinIO.
FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

ENV PIP_NO_CACHE_DIR=1
RUN pip install --no-cache-dir \
    mlflow==2.22.1 \
    psycopg2-binary==2.9.10 \
    boto3==1.35.99

EXPOSE 5000
